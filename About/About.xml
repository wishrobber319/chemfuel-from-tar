<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ModMetaData>
    <packageId>wishRobber.chemfuelfromtar</packageId>
    <name>Chemfuel from Tar</name>
    <author>wishRobber</author>
    <description>Fuel your medieval colony with tar instead of wood. Reworks Vanilla Factions Expanded – Medieval 2's chemfuel recipes to burn Medieval Overhaul's tar (gathered at the mine shaft) for a cohesive medieval fuel economy.</description>
    <supportedVersions>
        <li>1.6</li>
    </supportedVersions>
    <modDependencies>
        <li>
            <packageId>OskarPotocki.VFE.Medieval2</packageId>
            <displayName>Vanilla Factions Expanded - Medieval 2</displayName>
            <steamWorkshopUrl>steam://url/CommunityFilePage/3444347874</steamWorkshopUrl>
        </li>
        <li>
            <packageId>DankPyon.Medieval.Overhaul</packageId>
            <displayName>Medieval Overhaul</displayName>
            <steamWorkshopUrl>steam://url/CommunityFilePage/3219596926</steamWorkshopUrl>
        </li>
    </modDependencies>
    <loadAfter>
        <li>OskarPotocki.VFE.Medieval2</li>
        <li>DankPyon.Medieval.Overhaul</li>
        <li>joeownage.overlap.remover</li>
    </loadAfter>
</ModMetaData>
